@page "/index"
@using Juan_AmparoAP1_P1.Services
@using Juan_AmparoAP1_P1.Models
@using Microsoft.AspNetCore.Components.QuickGrid
@inject EntradasHuacalesServices EntradasHuacalesServices
@rendermode InteractiveServer

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Consulta de Entradas Huacales</h5>
        <a href="/create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Crear
        </a>
    </div>

    <div class="card-body">
        <div class="row mb-3 align-items-end">
            <div class="col-md-3">
                <label>Filtrar por:</label>
                <select class="form-select" @bind="filtroSeleccionado">
                    <option value="ID">ID Entrada</option>
                    <option value="Cliente">Cliente</option>
                </select>
            </div>
            <div class="col-md-3">
                <label>Búsqueda:</label>
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Escribe aquí..." @bind="valorFiltro" />
                </div>
            </div>
            <div class="col-md-3">
                <label>Desde:</label>
                <InputDate class="form-control" @bind-Value="filtroFechaDesde" />
            </div>
            <div class="col-md-3">
                <label>Hasta:</label>
                <div class="input-group">
                    <InputDate class="form-control" @bind-Value="filtroFechaHasta" />
                    <button class="btn btn-outline-primary" @onclick="Buscar">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                </div>
            </div>
        </div>

        <div class="row mb-2 text-end">
            <div class="col">
                <button class="btn btn-outline-secondary btn-sm" @onclick="Restablecer">
                    <i class="bi bi-arrow-clockwise"></i> Restablecer Filtros
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <QuickGrid Items="@lista.AsQueryable()" Pagination="@pagination" Class="table table-hover align-middle">
                <PropertyColumn Property="@(e => e.idEntrada)" Title="ID" Sortable="true" />
                <PropertyColumn Property="@(e => e.Fecha)" Title="Fecha" Format="dd/MM/yyyy" Sortable="true" />
                <PropertyColumn Property="@(e => e.NombreCliente)" Title="Cliente" Sortable="true" />
                <TemplateColumn Title="Total Huacales">
                    @context.EntradasDetalle.Sum(d => d.Cantidad)
                </TemplateColumn>
                <TemplateColumn Title="Monto Total">
                    @context.EntradasDetalle.Sum(d => d.Cantidad * d.Precio).ToString("N2")
                </TemplateColumn>
                <TemplateColumn Title="Acciones">
                    <a href="/edit/@context.idEntrada" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-pencil"></i> Editar
                    </a>
                </TemplateColumn>
            </QuickGrid>
        </div>
        <div class="card-footer">
            <Paginator State="@pagination" />
            <div class="mt-2 text-muted">
                Conteo: @lista.Count
            </div>
        </div>
    </div>
</div>

@code {
    public List<EntradasHuacales> lista { get; set; } = new List<EntradasHuacales>();
    public List<EntradasHuacales> listaCompleta { get; set; } = new List<EntradasHuacales>();

    public string filtroSeleccionado { get; set; } = "ID";
    public string valorFiltro { get; set; } = "";
    
    public DateTime? filtroFechaDesde { get; set; }
    public DateTime? filtroFechaHasta { get; set; }

    PaginationState pagination = new PaginationState { ItemsPerPage = 4 };

    protected override async Task OnInitializedAsync()
    {
        listaCompleta = await EntradasHuacalesServices.ObtenerTodos();
        lista = listaCompleta.ToList();
    }

    private void Buscar()
    {
        lista = listaCompleta.ToList();

        if (!string.IsNullOrWhiteSpace(valorFiltro))
        {
            if (filtroSeleccionado == "ID")
            {
                if (int.TryParse(valorFiltro, out int idBuscado))
                {
                    lista = lista.Where(e => e.idEntrada == idBuscado).ToList();
                }
            }
            else if (filtroSeleccionado == "Cliente")
            {
                lista = lista.Where(e => e.NombreCliente != null && e.NombreCliente.ToLower().Contains(valorFiltro.ToLower())).ToList();
            }
        }

        if (filtroFechaDesde.HasValue)
        {
            lista = lista.Where(e => e.Fecha.Date >= filtroFechaDesde.Value.Date).ToList();
        }

        if (filtroFechaHasta.HasValue)
        {
            lista = lista.Where(e => e.Fecha.Date <= filtroFechaHasta.Value.Date).ToList();
        }

        if (lista.Count == 0)
        {
            // Toast.ShowWarning("No se encontraron coincidencias");
        }
    }

    private void Restablecer()
    {
        filtroSeleccionado = "ID";
        valorFiltro = "";
        filtroFechaDesde = null;
        filtroFechaHasta = null;
        lista = listaCompleta.ToList();
    }
}